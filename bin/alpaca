#!/usr/bin/env python3
import argparse
import os
import sys
from pathlib import Path

from alpaca.trading.client import TradingClient
from alpaca.trading.enums import OrderSide, TimeInForce
from alpaca.trading.requests import GetOrdersRequest, MarketOrderRequest


DEFAULT_ENDPOINT = "https://paper-api.alpaca.markets/v2"


def load_env_file():
    env_path = Path.cwd() / ".env"
    if not env_path.exists():
        return

    for raw_line in env_path.read_text().splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        os.environ.setdefault(key.strip(), value.strip().strip('"').strip("'"))


def trading_client():
    load_env_file()
    key_id = os.environ.get("APCA_API_KEY_ID")
    secret_key = os.environ.get("APCA_API_SECRET_KEY")

    if not key_id or not secret_key:
        raise SystemExit(
            "Missing credentials. Set APCA_API_KEY_ID and APCA_API_SECRET_KEY "
            "in your environment or in .env."
        )

    return TradingClient(api_key=key_id, secret_key=secret_key, paper=True)


def print_account(_args):
    account = trading_client().get_account()
    print(f"status: {account.status}")
    print(f"currency: {account.currency}")
    print(f"cash: {account.cash}")
    print(f"portfolio_value: {account.portfolio_value}")
    print(f"buying_power: {account.buying_power}")
    print(f"pattern_day_trader: {account.pattern_day_trader}")
    print(f"trading_blocked: {account.trading_blocked}")


def print_positions(_args):
    positions = trading_client().get_all_positions()
    if not positions:
        print("No open positions.")
        return

    for position in positions:
        print(
            f"{position.symbol}: qty={position.qty} "
            f"market_value={position.market_value} unrealized_pl={position.unrealized_pl}"
        )


def print_orders(args):
    request = GetOrdersRequest(status=args.status, limit=args.limit)
    orders = trading_client().get_orders(filter=request)
    if not orders:
        print("No matching orders.")
        return

    for order in orders:
        print(
            f"{order.id} {order.symbol} {order.side} {order.order_type} "
            f"qty={order.qty} status={order.status} submitted_at={order.submitted_at}"
        )


def submit_market_order(args):
    side = OrderSide.BUY if args.side == "buy" else OrderSide.SELL
    request = MarketOrderRequest(
        symbol=args.symbol.upper(),
        qty=args.qty,
        side=side,
        time_in_force=TimeInForce.DAY,
    )
    order = trading_client().submit_order(order_data=request)
    print(f"submitted: {order.id}")
    print(f"symbol: {order.symbol}")
    print(f"side: {order.side}")
    print(f"qty: {order.qty}")
    print(f"status: {order.status}")


def main():
    parser = argparse.ArgumentParser(
        prog="alpaca",
        description="Small Alpaca paper-trading CLI backed by alpaca-py.",
    )
    parser.add_argument(
        "--endpoint",
        default=os.environ.get("APCA_API_BASE_URL", DEFAULT_ENDPOINT),
        help="Paper endpoint. Kept for compatibility; alpaca-py uses paper=True.",
    )
    subparsers = parser.add_subparsers(required=True)

    account = subparsers.add_parser("account", help="Show account summary.")
    account.set_defaults(func=print_account)

    positions = subparsers.add_parser("positions", help="List open positions.")
    positions.set_defaults(func=print_positions)

    orders = subparsers.add_parser("orders", help="List orders.")
    orders.add_argument("--status", default="open", choices=["open", "closed", "all"])
    orders.add_argument("--limit", type=int, default=50)
    orders.set_defaults(func=print_orders)

    market = subparsers.add_parser("market", help="Submit a paper market order.")
    market.add_argument("side", choices=["buy", "sell"])
    market.add_argument("symbol")
    market.add_argument("qty", type=float)
    market.set_defaults(func=submit_market_order)

    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        sys.exit(130)
